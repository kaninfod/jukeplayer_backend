# ============================================================================
# JUKEPLAYER BACKEND - LOCAL NETWORK CONFIGURATION
# ============================================================================
# This defines the active configuration for your Jukeplayer Backend
# All unused or hardcoded entries have been stripped out.
# Copy this file to .env or use it as `.env_dev` for local development.

# ============================================================================
# SERVER / API CONFIGURATION
# ============================================================================
# Note: Host and Port are determined by uvicorn args or docker-compose (not via this file)

# Toggles extra debugging traces across the app
DEBUG_MODE=false

# Toggles access to the Swagger UI (/docs) and OpenAPI schema (/openapi.json)
ENABLE_DOCS=true
DOCS_URL=/docs
OPENAPI_URL=/openapi.json

# API key for external protection. Can be left empty for local-only setup.
API_KEY=

# Local Network Security Bypasses 
CORS_ALLOW_ORIGINS=*
ENABLE_HTTPS_REDIRECT=false

# Allow 127.0.0.1 to access API without API key (for internal tools inside the app)
ALLOW_LOCAL_API_BYPASS=true

# ============================================================================
# LOGGING
# ============================================================================
# Application logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Centralized Syslog server (e.g., Unraid, Synology, Linux box)
# Leave host empty or set to 'localhost' to disable remote syslog.
LOG_SERVER_HOST= # 192.168.68.102
LOG_SERVER_PORT= # 514

# ============================================================================
# SUBSONIC / NAVIDROME MUSIC SOURCE 
# ============================================================================
# URL of your Navidrome or Subsonic server on the local network
SUBSONIC_URL=http://192.168.68.102:4747
# Your Subsonic user credentials
SUBSONIC_USER=jukebox
SUBSONIC_PASS=@J?_bjZ9?.Zdm1@z2zE0

# Client Identifier sent in Subsonic requests
SUBSONIC_CLIENT=JukeboxPi
SUBSONIC_API_VERSION=1.16.1

# Optional: Basic Auth if your Subsonic has reverse proxy authentication
SUBSONIC_PROXY_BASIC_USER=
SUBSONIC_PROXY_BASIC_PASS=

# ============================================================================
# AUDIO OUTPUT: PLAYBACK BACKEND
# ============================================================================
# Active hardware for audio output. Options: 'mpv' (local speaker), 'chromecast', 'streaming' (ESP32)
PLAYBACK_BACKEND=mpv

# === CHROMECAST CONFIGURATION ===
# Comma-separated list of Chromecast devices on your network
CHROMECAST_DEVICES=Living Room,Bedroom,Kitchen

# The default Chromecast used on startup
DEFAULT_CHROMECAST_DEVICE=Living Room

# Fallback devices strictly in priority order if the default is offline
CHROMECAST_FALLBACK_DEVICES=Bedroom,Kitchen

# Time in seconds to wait when scanning the network for Chromecasts
CHROMECAST_DISCOVERY_TIMEOUT=3

# Time in seconds to wait for casting device to become completely ready
CHROMECAST_WAIT_TIMEOUT=10

# === MPV (LOCAL SPEAKER) CONFIGURATION ===
# Which local binary to invoke for MPV
MPV_BINARY=mpv

# Socket used to issue commands to the MPV process
MPV_IPC_SOCKET=/tmp/jukebox-mpv.sock

# Output logging file specifically for the MPV daemon
MPV_LOG_FILE=/tmp/mpv-jukebox.log
MPV_MSG_LEVEL=all=info

# How long to wait until assuming MPV process crashed during startup
MPV_STARTUP_TIMEOUT_SECONDS=5

# Extra startup arguments to initialize MPV with (like volume constraints)
MPV_EXTRA_ARGS=--volume=40

# Interval to check memory and process health
MPV_DIAGNOSTIC_INTERVAL_SECONDS=20

# Time without playback activity before warning of a stall
MPV_STALL_WARNING_SECONDS=90

# Human friendly name for Local speaker
MPV_DEVICE_NAME=BOOM3

# ============================================================================
# TIMEOUTS & HARDWARE
# ============================================================================
# General HTTP request timeout for downloads like images/covers (in seconds)
HTTP_REQUEST_TIMEOUT=10

# (Below used by frontend/rpi if configured to read the same env source)
# Interval in seconds to poll RFID card reader
RFID_POLL_INTERVAL=1.0

# General Timeout threshold when actively reading an RFID card
RFID_READ_TIMEOUT=5.0