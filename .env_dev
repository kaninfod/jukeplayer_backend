# ============================================================================
# JUKEPLAYER BACKEND - LOCAL NETWORK CONFIGURATION
# ============================================================================
# This backend runs on your local network only (no external access)
# Copy this file to .env and customize for your setup

# === SERVER ===
SERVER_HOST=0.0.0.0        # Listen on all interfaces (firewall restricts access)
SERVER_PORT=8000
DEBUG_MODE=false
ENABLE_DOCS=true           # Enable FastAPI /docs and /openapi.json for testing
DOCS_URL=/docs
OPENAPI_URL=/openapi.json

# === LOGGING ===
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Syslog server (remote logging on your network)
# Point to your local syslog server (e.g., Unraid, synology, linux box)
# Leave empty or use localhost to disable syslog
LOG_SERVER_HOST=192.168.68.102    # Your syslog server IP
LOG_SERVER_PORT=514                # Standard syslog port (UDP)

# Local log file (fallback, created in ./logs/ directory)
LOG_FILE=logs/jukebox.log

# === LOCAL NETWORK ONLY ===
# Access only from your home network via http://192.168.x.x:8001
# Firewall provides external security - no external HTTPS/reverse proxy needed
# TrustedHostMiddleware disabled (not needed for local-only applications)
CORS_ALLOW_ORIGINS=*
ENABLE_HTTPS_REDIRECT=false
ALLOW_LOCAL_API_BYPASS=true

# === SECURITY ===
# API key removed for local-only setup
API_KEY=

# ============================================================================
# SUBSONIC / MUSIC SOURCE (Local Network Only)
# ============================================================================
SUBSONIC_URL=http://192.168.68.111:4747          # Local network URL for all clients (REST, Chromecast, WebSocket, etc)
SUBSONIC_USER=admin
SUBSONIC_PASS=admin
SUBSONIC_CLIENT=JukeboxPi
SUBSONIC_API_VERSION=1.16.1

# Optional: Basic Auth if your Subsonic has reverse proxy auth (local only)
SUBSONIC_PROXY_BASIC_USER=
SUBSONIC_PROXY_BASIC_PASS=

# ============================================================================
# AUDIO OUTPUT: PLAYBACK BACKEND
# ============================================================================
# Options: 'mpv' (local speaker), 'chromecast' (Chromecast device), 'streaming' (ESP32 streaming)
PLAYBACK_BACKEND=chromecast

# === CHROMECAST DEVICES ===
# All Chromecast devices available on your home network
CHROMECAST_DEVICES=Living Room,Bedroom,Kitchen
# Default device to use when backend starts
DEFAULT_CHROMECAST_DEVICE=Living Room
# Fallback devices to try if primary is offline (priority order)
CHROMECAST_FALLBACK_DEVICES=Bedroom,Kitchen
# Chromecast connection timeouts
CHROMECAST_DISCOVERY_TIMEOUT=3
CHROMECAST_WAIT_TIMEOUT=10

# === LOCAL MPV SPEAKER  ===
# Use only if you're casting to local speaker instead of Chromecast
MPV_BINARY=mpv
MPV_IPC_SOCKET=/tmp/jukebox-mpv.sock
MPV_STARTUP_TIMEOUT_SECONDS=5
MPV_EXTRA_ARGS=--volume=40
MPV_DIAGNOSTIC_INTERVAL_SECONDS=20
MPV_STALL_WARNING_SECONDS=90
MPV_MSG_LEVEL=all=info
MPV_LOG_FILE=/tmp/mpv-jukebox.log
MPV_DEVICE_NAME=BOOM3

# === BLUETOOTH AUDIO ===
# Bluetooth speaker for local playback 
BT_SPEAKER_MAC=10:94:97:0F:CB:BF
BT_AUTO_RECONNECT=true
MPV_AUDIO_DEVICE=pipewire/bluez_output.10_94_97_0F_CB_BF.1

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=sqlite:///./jukebox.db

# ============================================================================
# NFC CARD ENCODING
# ============================================================================
NFC_ENCODING_ENABLED=true

# ============================================================================
# TIMEOUTS & NETWORK
# ============================================================================
HTTP_REQUEST_TIMEOUT=10
RFID_POLL_INTERVAL=1.0
RFID_READ_TIMEOUT=5.0
